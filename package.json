{
  "name": "dungeon-rpg",
  "version": "1.0.0",
  "description": "Terminal Dungeon RPG + pixel-art web UI — portfolio project showcasing OOP, SOLID, and Clean Code in TypeScript",
  "main": "dist/main.js",
  "scripts": {
    "start":      "node dist/main.js",
    "web":        "tsx src/web-main.ts",
    "web:build":  "tsc && node dist/web-main.js",
    "dev":        "tsx src/main.ts",
    "build":      "tsc",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["rpg", "roguelike", "dungeon", "typescript", "oop", "clean-code", "solid", "websocket"],
  "license": "MIT",
  "dependencies": {
    "chalk":   "4.1.2",
    "express": "^4.18.2",
    "ws":      "^8.16.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node":    "^20.11.0",
    "@types/ws":      "^8.5.10",
    "tsx":            "^4.7.0",
    "typescript":     "^5.3.0"
  }
}
